---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Terms & Conditions"
  description="Terms and conditions for kristianazzet.com."
>
  <Nav transparent={true} />
  <main class="mx-auto max-w-2xl px-4 pb-24 pt-24 md:pt-28">
    <h1 class="text-3xl font-bold uppercase tracking-tight text-white">Terms & Conditions</h1>
    <p class="mt-8 text-sm leading-relaxed text-white/65">
      This page is a placeholder. Replace with your final terms and governing law when ready.
    </p>
  </main>
  <Footer />
</BaseLayout>
