---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title="DJ til firmafest — Kristian Azzet"
  description="Professionel DJ til din firmafest. 10+ års erfaring, 300+ shows, fuldt udstyr inkluderet. Kontakt for tilbud."
  noindex={true}
>
  <!-- Nav med glass ved scroll -->
  <nav
    id="firmafest-nav"
    class="fixed top-0 left-0 right-0 z-30 flex justify-center items-center px-6 md:px-8 py-5 md:py-6 transition-all duration-500 ease-out"
  >
    <img
      src="/images/MAIN_LOGO_-_HVID.svg"
      alt="Kristian Azzet"
      class="h-6 md:h-8 w-auto drop-shadow-[0_2px_24px_rgba(0,0,0,0.45)]"
    />
  </nav>

  <!-- Sticky CTA bar på mobil -->
  <div class="fixed bottom-0 left-0 right-0 z-40 flex gap-2 border-t border-white/[0.06] bg-void/95 px-4 py-3 backdrop-blur-xl md:hidden">
    <a
      href="#kontakt"
      class="flex-1 bg-neon-green text-stone-black px-4 py-3 text-center text-sm font-bold uppercase tracking-[0.12em] md:text-base"
    >
      Få tilbud
    </a>
    <a
      href={`tel:${siteConfig.firmafest.phone.replace(/\s/g, '')}`}
      class="border border-white/30 px-4 py-3 text-sm font-bold uppercase tracking-[0.12em] text-white md:text-base"
    >
      Ring
    </a>
  </div>

  <main class="pb-28 md:pb-0">
  <!-- HERO — fuld højde, Ken Burns, grain, vignette -->
  <section class="relative min-h-[100dvh] flex w-full flex-col items-center justify-center overflow-hidden px-4 pt-28 pb-28 text-center sm:px-6 lg:px-10 xl:px-14">
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div
        class="hero-bg-static absolute inset-0 bg-cover bg-center will-change-transform motion-reduce:animate-none animate-hero-ken"
        style="background-image: url(/images/firmafest-hero.jpg); background-color: #2d3d1a;"
      ></div>
      <div class="noise-overlay" aria-hidden="true"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-stone-black/45 to-void"></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_90%_65%_at_50%_16%,rgba(220,255,66,0.045),transparent_55%)]"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-0 bg-[radial-gradient(ellipse_130%_85%_at_50%_100%,rgba(0,0,0,0.72),transparent_52%)]"
        aria-hidden="true"
      ></div>
    </div>

    <div class="relative z-10 max-w-4xl">
      <p
        class="ka-label ka-label--accent animate-fade-up mb-8 opacity-0"
        style="animation-delay: 0.05s"
      >
        DJ til firmafest · Hele Danmark
      </p>

      <h1
        class="opacity-0 font-display text-5xl leading-[0.94] tracking-tight animate-fade-up [text-shadow:0_6px_56px_rgba(0,0,0,0.65)] sm:text-6xl md:text-7xl lg:text-8xl"
        style="animation-delay: 0.14s"
      >
        GIV DIN FIRMAFEST<br/>EN AFTEN DE HUSKER
      </h1>

      <p
        class="opacity-0 text-base md:text-lg text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up"
        style="animation-delay: 0.24s"
      >
        Professionel DJ med 10+ års erfaring og 300+ events bag sig. Fra Smukfest til LEGO, Visma og Lunar — jeg leverer den oplevelse dine kollegaer taler om mandag morgen.
      </p>

      <div class="opacity-0 flex flex-wrap gap-3 justify-center mb-10 animate-fade-up" style="animation-delay: 0.34s">
        <a
          href="#kontakt"
          class="ka-btn bg-neon-green px-10 py-4 text-stone-black shadow-[0_8px_32px_rgba(220,255,66,0.22)] transition-default hover:scale-[1.02] hover:bg-white active:scale-[0.99]"
          data-event="cta_hero_primary"
        >
          Få et uforpligtende tilbud →
        </a>
        <a
          href={`tel:${siteConfig.firmafest.phone.replace(/\s/g, '')}`}
          class="ka-btn border border-white/45 bg-white/5 px-10 py-4 text-white backdrop-blur-[2px] transition-default hover:scale-[1.02] hover:bg-white hover:text-stone-black active:scale-[0.99]"
          data-event="cta_hero_call"
        >
          Ring {siteConfig.firmafest.phone}
        </a>
      </div>

      <!-- Trust indicators -->
      <div
        class="opacity-0 mx-auto flex max-w-2xl flex-wrap justify-center gap-6 border-t border-white/[0.06] pt-10 text-center md:gap-10 animate-fade-up"
        style="animation-delay: 0.44s"
      >
        <div>
          <div class="font-display text-3xl md:text-4xl text-neon-green tabular-nums">300+</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wide text-white/65">Events</div>
        </div>
        <div>
          <div class="font-display text-3xl md:text-4xl text-neon-green tabular-nums">10+</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wide text-white/65">Års erfaring</div>
        </div>
        <div>
          <div class="font-display text-3xl md:text-4xl text-neon-green tabular-nums">1.800</div>
          <div class="mt-1 text-[11px] font-medium uppercase tracking-wide text-white/65">Timer på decks</div>
        </div>
      </div>
    </div>

    <a
      href="#tidligere-kunder"
      class="absolute bottom-10 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/55 transition-colors hover:text-white"
      aria-label="Scroll til indhold"
    >
      <span>Scroll</span>
      <span class="relative flex h-12 w-5 justify-center overflow-hidden">
        <span class="absolute top-0 h-8 w-px bg-gradient-to-b from-neon-green/90 via-neon-green/40 to-transparent motion-reduce:animate-none animate-scroll-hint"></span>
      </span>
    </a>
  </section>

  <!-- SOCIAL PROOF — marquee, større type som artist-roster -->
  <section id="tidligere-kunder" class="border-t border-white/[0.06] bg-void px-4 sm:px-6 lg:px-10 xl:px-14 py-20 md:py-28" data-reveal>
    <div class="w-full">
      <div class="mb-14 text-center">
        <p class="ka-label ka-label--accent mb-3">Tidligere kunder</p>
        <p class="text-base text-white/70 md:text-lg">Nogle af de brands der har booket mig</p>
      </div>
      <div class="group/marquee relative overflow-hidden border-y border-white/[0.06] py-10 [mask-image:linear-gradient(90deg,transparent,black_10%,black_90%,transparent)]">
        <div
          class="flex w-max animate-marquee items-center gap-x-14 md:gap-x-20 motion-reduce:animate-none group-hover/marquee:[animation-play-state:paused]"
        >
          {[...siteConfig.clients, ...siteConfig.clients].map((client) => (
            <span class="shrink-0 font-display text-lg font-bold tracking-wide text-white/90 md:text-2xl">
              {client.toUpperCase()}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- HVAD FÅR I — editorial liste (mindre “kasser”) -->
  <section class="border-t border-white/[0.06] bg-stone-black-dark px-4 sm:px-6 lg:px-10 xl:px-14 py-24 md:py-32" data-reveal>
    <div class="w-full">
      <div class="mb-16 max-w-2xl text-center md:mx-auto">
        <p class="ka-label ka-label--accent mb-4">Hvad får i</p>
        <h2 class="font-display text-4xl tracking-tight md:text-5xl md:tracking-tight">ALT INKLUDERET</h2>
        <p class="mt-5 text-sm leading-relaxed text-white/72 md:text-base">
          Ingen skjulte priser, ingen sidste øjebliks tilkøb. Jeg medbringer det hele og sørger for at alt spiller.
        </p>
      </div>

      <div class="border-t border-white/[0.06]">
        <article class="grid gap-8 border-b border-white/[0.06] py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">01</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">PROFESSIONELT LYDUDSTYR</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Højtalere og subs tilpasset jeres lokale. Fra intim afdeling til storsal — lyden er altid clean og kraftfuld hvor den skal være.
            </p>
          </div>
        </article>
        <article class="grid gap-8 border-b border-white/[0.06] py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">02</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">LYS & ATMOSFÆRE</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Stemningsbelysning og effekter der skaber dansegulvs-vibe uden at dominere. Setuppet tilpasses lokalet.
            </p>
          </div>
        </article>
        <article class="grid gap-8 border-b border-white/[0.06] py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">03</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">MUSIK TIL HELE AFTENEN</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Fra baggrund under middag til dansegulv kl. 02. Jeg læser lokalet og justerer i realtid — det er ikke en playliste, det er en aften der er bygget op.
            </p>
          </div>
        </article>
        <article class="grid gap-8 border-b border-white/[0.06] py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">04</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">SETUP & NEDTAGNING</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Ankomst 2 timer før start, soundcheck, tjek med jeres kontaktperson. Alt pakkes ned og ryddes op efter festen.
            </p>
          </div>
        </article>
        <article class="grid gap-8 border-b border-white/[0.06] py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">05</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">ØNSKEMUSIK & SPECIAL REQUESTS</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Har I en særlig sang eller en kollega der skal hyldes? Vi afstemmer på forhånd, og jeg læser gæsterne på aftenen.
            </p>
          </div>
        </article>
        <article class="grid gap-8 py-10 md:grid-cols-12 md:gap-10 md:py-14">
          <div class="font-display text-3xl text-neon-green/90 tabular-nums md:col-span-2">06</div>
          <div class="md:col-span-10">
            <h3 class="font-display text-xl tracking-tight text-white md:text-2xl">FORSIKRET & PROFESSIONELT</h3>
            <p class="mt-3 max-w-2xl text-sm leading-relaxed text-white/75 md:text-[15px]">
              Fuldt momsregistreret, forsikret, og med skriftlig kontrakt. I ved præcis hvad I får, og hvornår.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- PROCES -->
  <section class="border-t border-white/[0.06] px-4 sm:px-6 lg:px-10 xl:px-14 py-24 md:py-32" data-reveal>
    <div class="w-full">
      <div class="mb-16 text-center">
        <p class="ka-label ka-label--accent mb-4">Sådan foregår det</p>
        <h2 class="font-display text-4xl tracking-tight md:text-5xl md:tracking-tight">FRA KONTAKT TIL FEST</h2>
      </div>

      <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8 lg:gap-12">
        <div class="border-t border-neon-green/70 pt-6">
          <p class="ka-label ka-label--accent mb-3">Step 01</p>
          <h3 class="font-display text-xl tracking-tight text-white">I SENDER DETALJER</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/72">
            Dato, antal gæster, lokale, og hvilken vibe I søger. Tager 2 minutter.
          </p>
        </div>
        <div class="border-t border-neon-green/70 pt-6">
          <p class="ka-label ka-label--accent mb-3">Step 02</p>
          <h3 class="font-display text-xl tracking-tight text-white">I FÅR ET TILBUD</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/72">
            Skriftligt tilbud indenfor 24 timer. Fast pris, ingen overraskelser.
          </p>
        </div>
        <div class="border-t border-neon-green/70 pt-6">
          <p class="ka-label ka-label--accent mb-3">Step 03</p>
          <h3 class="font-display text-xl tracking-tight text-white">JEG LEVERER</h3>
          <p class="mt-3 text-sm leading-relaxed text-white/72">
            På aftenen: ankomst, setup, show, oprydning. I fokuserer på gæsterne.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="border-t border-white/[0.06] bg-void px-4 sm:px-6 lg:px-10 xl:px-14 py-24 md:py-32" data-reveal>
    <div class="w-full">
      <div class="mb-16 text-center">
        <p class="ka-label ka-label--accent mb-4">Hvad kunderne siger</p>
        <h2 class="font-display text-4xl tracking-tight md:text-5xl md:tracking-tight">REFERENCER</h2>
      </div>

      <div class="grid grid-cols-1 gap-px overflow-hidden border border-white/[0.06] bg-white/[0.06] md:grid-cols-2">
        <figure class="m-0 bg-void p-8 md:p-10">
          <div class="font-display text-4xl leading-none text-neon-green/90">"</div>
          <blockquote class="m-0 mt-4 text-base italic leading-relaxed text-white/[0.82]">
            Testimonial placeholder — når du har rigtige citater fra firmafester, kommer de ind her. Kunde, firma, eventuelt billede.
          </blockquote>
          <figcaption class="mt-8 border-t border-white/[0.06] pt-6">
            <div class="text-sm font-bold text-white">[Kundens navn]</div>
            <div class="mt-1 text-xs text-white/50">[Firma · Event]</div>
          </figcaption>
        </figure>

        <figure class="m-0 bg-void p-8 md:p-10">
          <div class="font-display text-4xl leading-none text-neon-green/90">"</div>
          <blockquote class="m-0 mt-4 text-base italic leading-relaxed text-white/[0.82]">
            Testimonial placeholder — send mig de citater du har fra tidligere firmafester, så lægger jeg dem ind.
          </blockquote>
          <figcaption class="mt-8 border-t border-white/[0.06] pt-6">
            <div class="text-sm font-bold text-white">[Kundens navn]</div>
            <div class="mt-1 text-xs text-white/50">[Firma · Event]</div>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-white/[0.06] px-4 sm:px-6 lg:px-10 xl:px-14 py-24 md:py-32" data-reveal>
    <div class="mx-auto max-w-3xl">
      <div class="mb-14 text-center">
        <p class="ka-label ka-label--accent mb-4">Typiske spørgsmål</p>
        <h2 class="font-display text-4xl tracking-tight md:text-5xl md:tracking-tight">FAQ</h2>
      </div>

      <div class="border-t border-white/[0.06]">
        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-bold md:text-base">
            <span class="text-left">Hvad koster det?</span>
            <span class="shrink-0 text-neon-green transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-sm leading-relaxed text-white/72">
            Prisen afhænger af antal gæster, lokale, varighed og udstyrsbehov. Send mig detaljerne via formularen, så får I et konkret tilbud indenfor 24 timer.
          </div>
        </details>

        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-bold md:text-base">
            <span class="text-left">Hvor kører du hen?</span>
            <span class="shrink-0 text-neon-green transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-sm leading-relaxed text-white/72">
            Hele Danmark. Base i Aarhus, men jeg kører gladeligt til København, Aalborg, Odense og alt derimellem. Ved kørsel udenfor Jylland indregnes transport i tilbuddet.
          </div>
        </details>

        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-bold md:text-base">
            <span class="text-left">Kan I booke mig sidste øjeblik?</span>
            <span class="shrink-0 text-neon-green transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-sm leading-relaxed text-white/72">
            Send mig dato og detaljer, så tjekker jeg kalenderen og svarer hurtigt. Nogle weekender er fyldt langt ud i fremtiden, men der kommer også afbud.
          </div>
        </details>

        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-bold md:text-base">
            <span class="text-left">Hvad slags musik spiller du?</span>
            <span class="shrink-0 text-neon-green transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-sm leading-relaxed text-white/72">
            Til firmafester tilpasser jeg musikken til publikummet. Typisk mix af hits, house og crowd-pleasers der får alle aldre med. Min baggrund er house og melodic techno, men til corporate events er det crowd-reading der styrer — ikke genre.
          </div>
        </details>

        <details class="group border-b border-white/[0.06]">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-sm font-bold md:text-base">
            <span class="text-left">Medbringer I lyd og lys selv?</span>
            <span class="shrink-0 text-neon-green transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="pb-6 text-sm leading-relaxed text-white/72">
            Ja — standard pakken inkluderer lyd- og lysudstyr der matcher lokalets størrelse. Har I allerede udstyr i huset, kan vi tale om en reduceret pris.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- KONTAKT FORMULAR -->
  <section id="kontakt" class="border-t border-white/[0.06] bg-stone-black-dark px-4 sm:px-6 lg:px-10 xl:px-14 py-24 md:py-32" data-reveal>
    <div class="mx-auto max-w-3xl">
      <div class="mb-12 text-center">
        <p class="ka-label ka-label--accent mb-4">Få et tilbud</p>
        <h2 class="mb-4 font-display text-4xl tracking-tight md:text-5xl md:tracking-tight">LAD OS TAGE EN SNAK</h2>
        <p class="mx-auto max-w-lg text-sm leading-relaxed text-white/72">
          Udfyld formularen, så vender jeg tilbage indenfor 24 timer med et konkret tilbud. Ingen forpligtelser.
        </p>
      </div>

      <form id="firmafest-form" class="flex flex-col gap-5 border border-white/[0.08] bg-black/25 p-6 md:p-10" method="POST" action="/api/firmafest">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Navn *</label>
            <input
              type="text"
              name="name"
              required
              class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Firma *</label>
            <input
              type="text"
              name="company"
              required
              class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Email *</label>
            <input
              type="email"
              name="email"
              required
              class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Telefon *</label>
            <input
              type="tel"
              name="phone"
              required
              class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Event dato *</label>
            <input
              type="date"
              name="eventDate"
              required
              class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Antal gæster *</label>
            <select
              name="guests"
              required
              class="w-full border border-white/[0.12] bg-void px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
            >
              <option value="">Vælg antal</option>
              <option value="0-50">0-50</option>
              <option value="50-100">50-100</option>
              <option value="100-250">100-250</option>
              <option value="250-500">250-500</option>
              <option value="500+">500+</option>
            </select>
          </div>
        </div>

        <div>
          <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Lokale / adresse</label>
          <input
            type="text"
            name="venue"
            class="w-full border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
          />
        </div>

        <div>
          <label class="mb-2 block text-xs font-medium uppercase tracking-wide text-white/60">Fortæl om jeres event</label>
          <textarea
            name="message"
            rows="4"
            placeholder="Type fest, varighed, særlige ønsker, musik-retning osv."
            class="w-full resize-none border border-white/[0.12] bg-transparent px-4 py-3.5 text-sm text-white transition-default focus:border-neon-green focus:outline-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="ka-btn mt-2 cursor-pointer bg-neon-green px-8 py-4 text-stone-black transition-default hover:bg-white hover:shadow-[0_12px_40px_rgba(220,255,66,0.18)]"
          data-event="cta_form_submit"
        >
          Send forespørgsel →
        </button>

        <div id="firmafest-message" class="text-center text-sm hidden mt-2"></div>

        <p class="text-[11px] text-white/40 text-center mt-2 leading-relaxed">
          Ved at sende forespørgslen godkender du at vi må kontakte dig. Dine oplysninger deles ikke med tredjepart.
        </p>
      </form>

      <!-- Alternative kontakt -->
      <div class="mt-12 border-t border-white/[0.06] pt-10 text-center">
        <div class="ka-label mb-4">Eller ring direkte</div>
        <a
          href={`tel:${siteConfig.firmafest.phone.replace(/\s/g, '')}`}
          class="font-display text-3xl text-neon-green hover:text-white transition-default"
        >
          {siteConfig.firmafest.phone}
        </a>
      </div>
    </div>
  </section>

  </main>

  <Footer />
</BaseLayout>

<script>
  (function initFirmafestChrome() {
    const nav = document.getElementById('firmafest-nav');
    function updateNav() {
      if (!nav) return;
      nav.classList.toggle('is-scrolled', window.scrollY > 48);
    }
    updateNav();
    window.addEventListener('scroll', updateNav, { passive: true });

    const revealEls = document.querySelectorAll('[data-reveal]');
    if (revealEls.length) {
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('reveal-visible');
              obs.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.06, rootMargin: '0px 0px -6% 0px' }
      );
      revealEls.forEach((el) => io.observe(el));
    }
  })();

  const form = document.getElementById('firmafest-form') as HTMLFormElement | null;
  const message = document.getElementById('firmafest-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !message) return;

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (button) {
      button.disabled = true;
      button.textContent = 'Sender...';
    }

    try {
      const response = await fetch('/api/firmafest', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        message.textContent = 'Tak — jeg vender tilbage indenfor 24 timer.';
        message.className = 'text-center text-sm text-neon-green block mt-2';
        form.reset();

        // Fire conversion event til GTM/stape hvis tilstede
        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            event: 'firmafest_lead',
            form_name: 'firmafest_contact',
          });
        }
      } else {
        message.textContent = 'Noget gik galt — prøv igen eller ring direkte.';
        message.className = 'text-center text-sm text-red-400 block mt-2';
      }
    } catch {
      message.textContent = 'Noget gik galt — prøv igen eller ring direkte.';
      message.className = 'text-center text-sm text-red-400 block mt-2';
    } finally {
      if (button) {
        button.disabled = false;
        button.textContent = 'Send forespørgsel →';
      }
    }
  });
</script>
