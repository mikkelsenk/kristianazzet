---
import { siteConfig } from '../config/site';

export interface Props {
  /** Lille label over overskrift (fx "LIVE") — tom = skjules */
  eyebrow?: string;
  /** Flere linjer: brug \n i site.ts */
  title?: string;
  body?: string;
  videoUrl?: string;
  thumbnailUrl?: string;
  /** Under video — som Smukfest-blokken i FeaturedVideo */
  meta?: {
    leftTitle?: string;
    leftSubtitle?: string;
    centerLabel?: string;
    rightLabel?: string;
  };
  sectionId?: string;
}

function youtubeVideoId(url: string): string | null {
  const m = url.match(
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/
  );
  return m?.[1] ?? null;
}

const cfg = siteConfig.homeSpotlight;
const {
  eyebrow = cfg.eyebrow,
  title = cfg.title,
  body = cfg.body,
  videoUrl = cfg.videoUrl,
  thumbnailUrl = cfg.thumbnailUrl,
  meta = cfg.meta,
  sectionId = 'spotlight',
} = Astro.props;

const safeVideoUrl = typeof videoUrl === 'string' ? videoUrl.trim() : '';
const ytId = safeVideoUrl ? youtubeVideoId(safeVideoUrl) : null;
const thumbSrc =
  (thumbnailUrl && thumbnailUrl.trim().length > 0
    ? thumbnailUrl.trim()
    : ytId
      ? `https://i.ytimg.com/vi/${ytId}/maxresdefault.jpg`
      : '') || '';

const eyebrowTrim = typeof eyebrow === 'string' ? eyebrow.trim() : '';
---

<section
  id={sectionId}
  class="w-full border-t border-white/10 bg-black px-4 py-24 sm:px-6 md:py-28 lg:px-10 xl:px-14"
  aria-labelledby={`${sectionId}-heading`}
>
  <div class="mx-auto w-full max-w-[min(100%,90rem)]">
    {
      eyebrowTrim ? (
        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-neon-green">
          {eyebrowTrim}
        </p>
      ) : null
    }

    <h2
      id={`${sectionId}-heading`}
      class="max-w-4xl whitespace-pre-line text-balance font-display text-3xl font-bold uppercase leading-[1.05] tracking-tight text-white sm:text-4xl md:text-5xl md:leading-[1.02]"
    >
      {title}
    </h2>

    <p
      class="mt-6 max-w-3xl text-base leading-relaxed text-white/70 md:text-lg md:leading-relaxed"
    >
      {body}
    </p>

    {
      safeVideoUrl ? (
        <div class="mt-10 md:mt-12">
          <a
            href={safeVideoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block aspect-video overflow-hidden border-2 border-white/90 bg-neutral-900"
            style={thumbSrc
              ? `background-image: url(${thumbSrc}); background-size: cover; background-position: center;`
              : 'background: linear-gradient(145deg, #1c1c1c 0%, #000 100%);'}
          >
            <div class="absolute inset-0 bg-black/25 transition-colors group-hover:bg-black/45"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div
                class="flex h-16 w-16 items-center justify-center bg-white text-black transition-transform group-hover:scale-105 md:h-20 md:w-20"
              >
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="ml-1">
                  <path d="M8 5v14l11-7z"></path>
                </svg>
              </div>
            </div>
          </a>
        </div>
      ) : null
    }

    {
      meta &&
      (meta.leftTitle ||
        meta.leftSubtitle ||
        meta.centerLabel ||
        meta.rightLabel) ? (
        <div class="mt-8 grid gap-6 border-t border-white/10 pt-8 text-sm md:grid-cols-3 md:text-base">
          <div>
            {meta.leftTitle ? (
              <p class="font-bold uppercase tracking-wide text-white">{meta.leftTitle}</p>
            ) : null}
            {meta.leftSubtitle ? (
              <p class="mt-1 text-white/65">{meta.leftSubtitle}</p>
            ) : null}
          </div>
          <div class="md:text-center">
            {meta.centerLabel ? (
              <p class="font-semibold uppercase tracking-wide text-neon-green">{meta.centerLabel}</p>
            ) : null}
          </div>
          <div class="md:text-right">
            {meta.rightLabel ? (
              <p class="font-bold uppercase tracking-wide text-white">{meta.rightLabel}</p>
            ) : null}
          </div>
        </div>
      ) : null
    }
  </div>
</section>
