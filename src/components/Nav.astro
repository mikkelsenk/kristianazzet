---
import { siteConfig } from '../config/site';

export interface Props {
  transparent?: boolean;
  /** Header tone on the page behind it */
  tone?: 'dark' | 'light';
}

const { transparent = true, tone = 'dark' } = Astro.props;
const isLight = tone === 'light';
const useAutoInvert = transparent;

const items = siteConfig.nav;

const roman = ['I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X'];
const descriptions: Record<string, string> = {
  Home: 'Start here',
  Shows: 'Upcoming shows',
  Music: 'Video & releases',
  Contact: 'Booking & press',
};

/** Kun disse fire i menu (højre) — som reference */
const menuSocials: { label: string; href: string }[] = [
  { label: 'Instagram', href: siteConfig.social.instagram },
  { label: 'YouTube', href: siteConfig.social.youtube },
  { label: 'Spotify', href: siteConfig.music.spotify },
  { label: 'Twitter', href: siteConfig.social.twitter },
];
---

<header
  id="ka-site-header"
  class:list={[
    'ka-header-bar fixed left-0 right-0 top-0 z-30 box-border py-5 pr-[var(--ka-sb,0px)] md:py-6',
    useAutoInvert ? 'ka-header--invert border-b border-transparent' : isLight ? 'border-b border-black/10' : 'border-b border-white/10',
    { 'bg-black/80 backdrop-blur-xl': !transparent },
  ]}
>
  <nav
    class="ka-topbar-row mx-auto flex w-full max-w-[100vw] items-center justify-between gap-4 px-[clamp(1rem,4vw,3rem)]"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class:list={[
        'flex h-8 w-8 shrink-0 items-center justify-center opacity-95 transition-opacity hover:opacity-100 md:h-9 md:w-9',
        useAutoInvert ? 'ka-header-invert' : '',
      ]}
      aria-label="Kristian Azzet — home"
    >
      <img
        id="ka-nav-logo"
        src={useAutoInvert ? "/images/ICON_-_HVID.svg" : isLight ? "/images/ICON_-_SORT.svg" : "/images/ICON_-_HVID.svg"}
        data-src-light="/images/ICON_-_SORT.svg"
        data-src-dark="/images/ICON_-_HVID.svg"
        alt=""
        width="36"
        height="36"
        class="h-full w-full object-contain"
        role="presentation"
      />
      <span class="sr-only">Kristian Azzet</span>
    </a>

    <!-- Fixed-width slot: Menu/Close swap without shifting the right edge -->
    <button
      id="site-menu-toggle"
      type="button"
      class:list={[
        "ka-menu-toggle relative flex shrink-0 items-center justify-end transition-opacity hover:opacity-90",
        useAutoInvert ? "ka-header-invert text-white" : isLight ? "text-black" : "text-white",
      ]}
      aria-expanded="false"
      aria-controls="site-menu-overlay"
      aria-label="Open menu"
    >
      <span class="ka-menu-toggle__slot">
        <span class="ka-menu-hamburger flex items-center justify-end gap-3" aria-hidden="true">
          <span class="flex flex-col gap-[7px]">
            <span
              class:list={[
                "ka-burger-line ka-burger-line--a h-0.5 w-9",
                useAutoInvert ? "bg-white" : isLight ? "bg-black" : "bg-white",
              ]}
            ></span>
            <span
              class:list={[
                "ka-burger-line ka-burger-line--b h-0.5 w-9",
                useAutoInvert ? "bg-white" : isLight ? "bg-black" : "bg-white",
              ]}
            ></span>
          </span>
          <span class="text-sm font-bold uppercase tracking-[0.18em] md:text-base">Menu</span>
        </span>
        <span class="ka-menu-close flex items-center justify-end gap-3" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </span>
      </span>
    </button>
  </nav>
</header>

<div
  id="site-menu-overlay"
  class="ka-menu-overlay fixed inset-0 z-[100] box-border flex flex-col bg-black pr-[var(--ka-sb,0px)]"
  role="dialog"
  aria-modal="true"
  aria-label="Menu"
  aria-hidden="true"
>
  <!-- Left rail: vertical MENU + line (Garrix-style) -->
  <div
    class="pointer-events-none absolute left-4 top-1/2 z-[1] hidden -translate-y-1/2 flex-col items-center gap-4 md:left-8 md:flex"
    aria-hidden="true"
  >
    <p
      class="rotate-180 text-[10px] font-semibold uppercase tracking-[0.38em] text-white/70 [writing-mode:vertical-rl] [text-orientation:mixed]"
    >
      Menu
    </p>
    <div class="h-[min(22vh,8.5rem)] w-px shrink-0 bg-white/35"></div>
  </div>

  <div
    class="ka-menu-topbar ka-topbar-row absolute left-0 right-0 top-0 flex items-center justify-between gap-4 border-b border-white/10 bg-black/80 px-[clamp(1rem,4vw,3rem)] py-5 backdrop-blur-xl md:py-6"
  >
    <a href="/" class="flex h-8 w-8 shrink-0 items-center justify-center md:h-9 md:w-9" aria-label="Back to home">
      <img src="/images/ICON_-_HVID.svg" alt="" width="36" height="36" class="h-full w-full object-contain" />
    </a>
    <button
      id="site-menu-close"
      type="button"
      class="ka-menu-topbar-close flex items-center justify-end text-white transition-opacity hover:opacity-80"
      aria-label="Close menu"
    >
      <span class="sr-only">Close menu</span>
      <span class="ka-menu-topbar-close-slot">
        <svg
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          class="shrink-0"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </span>
    </button>
  </div>

  <div class="flex min-h-0 flex-1 flex-col pt-[76px] md:pt-[88px]">
    <div class="flex min-h-0 flex-1 flex-col md:min-h-0 md:items-center md:justify-center">
      <nav
        class="ka-menu-panel flex min-h-0 w-full max-w-[min(100%,760px)] flex-col justify-center overflow-y-auto px-8 py-10 md:px-10 md:py-12 lg:px-16 lg:py-16 xl:px-20"
        aria-label="Site links"
      >
        <ul class="ka-menu-list flex min-h-0 flex-col justify-center">
          {items.map(({ label, href }, i) => (
            <li class="ka-menu-item border-b border-white/10 py-5 md:py-6">
              <a
                href={href}
                class="group grid grid-cols-[40px_1fr] items-baseline gap-4 md:grid-cols-[56px_1fr] md:gap-6"
              >
                <span class="text-xs font-semibold text-white/70">{roman[i] ?? (i + 1)}</span>
                <div class="flex items-baseline justify-between gap-6">
                  <span class="font-display text-3xl uppercase tracking-tight text-white transition-opacity group-hover:opacity-80 md:text-5xl">
                    {label}
                  </span>
                  <span class="hidden text-sm text-white/75 md:block">{descriptions[label] ?? ''}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <!-- Fælles fodlinje: én streg på tværs, venstre/højre på samme baseline -->
    <div
      class="ka-menu-footer-bar shrink-0 border-t border-white/10 text-xs font-semibold uppercase tracking-[0.12em] text-white/75"
    >
      <div
        class="flex flex-col gap-4 px-8 py-6 sm:flex-row sm:items-center sm:justify-between sm:gap-6 md:px-10 lg:px-16 xl:px-20"
      >
        <div class="flex min-w-0 flex-nowrap items-center gap-x-6 sm:gap-x-8">
          <a
            href={siteConfig.pressKitUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="shrink-0 underline decoration-white/25 underline-offset-[6px] transition-colors hover:text-white"
          >
            Press kit
          </a>
          <a
            href="/music"
            class="shrink-0 underline decoration-white/25 underline-offset-[6px] transition-colors hover:text-white"
          >
            Music
          </a>
        </div>
        <div class="flex min-w-0 flex-nowrap items-center justify-start gap-x-6 overflow-x-auto sm:justify-end sm:gap-x-8">
          {menuSocials.map(({ label, href }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 whitespace-nowrap transition-colors hover:text-white"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Auto-contrast: solid på sort/hvid, exclusion over “alt andet”.
  const header = document.getElementById('ka-site-header');
  const logo = document.getElementById('ka-nav-logo');
  const toggle = document.getElementById('site-menu-toggle');

  const isAuto = header?.classList.contains('ka-header--invert');

  function setHeaderMode(mode) {
    if (!header) return;
    header.classList.toggle('ka-nav-mode--solid-light', mode === 'light');
    header.classList.toggle('ka-nav-mode--solid-dark', mode === 'dark');
    header.classList.toggle('ka-nav-mode--blend', mode === 'blend');

    // Logo: light bg = sort logo, ellers hvid logo.
    if (logo instanceof HTMLImageElement) {
      const lightSrc = logo.dataset.srcLight || '';
      const darkSrc = logo.dataset.srcDark || '';
      if (mode === 'light' && lightSrc) logo.src = lightSrc;
      if ((mode === 'dark' || mode === 'blend') && darkSrc) logo.src = darkSrc;
    }

    // Toggle: light bg = sort tekst/linjer, ellers hvid (blend bruger exclusion).
    const lines = toggle?.querySelectorAll('.ka-burger-line');
    lines?.forEach((el) => {
      el.classList.toggle('bg-black', mode === 'light');
      el.classList.toggle('bg-white', mode !== 'light');
    });
    toggle?.classList.toggle('text-black', mode === 'light');
    toggle?.classList.toggle('text-white', mode !== 'light');
  }

  function findToneAtHeader() {
    // Punkt ved logoet (øverst venstre). Hvis sektion angiver data-nav-tone, bruger vi det.
    const y = 18;
    const x = 28;
    const el = document.elementFromPoint(x, y);
    const toneEl = el?.closest?.('[data-nav-tone]');
    const tone = toneEl?.getAttribute?.('data-nav-tone') || '';
    if (tone === 'light' || tone === 'dark' || tone === 'blend') return tone;
    return '';
  }

  if (isAuto) {
    let raf = 0;
    const tick = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        const tone = findToneAtHeader();
        // Default: dark (hvid). Sektioner kan override.
        setHeaderMode(tone || 'dark');
      });
    };
    window.addEventListener('scroll', tick, { passive: true });
    window.addEventListener('resize', tick, { passive: true });
    tick();
  }

  const close = document.getElementById('site-menu-close');
  const menu = document.getElementById('site-menu-overlay');
  let isAnimating = false;
  const ANIM_MS = 320;
  const toggleButton = toggle;

  function scrollbarWidth() {
    const w = window.innerWidth - document.documentElement.clientWidth;
    return Math.max(0, Math.ceil(w));
  }

  function setScrollLock(on) {
    if (on) {
      const w = scrollbarWidth();
      document.documentElement.style.setProperty('--ka-sb', w > 0 ? `${w}px` : '0px');
      document.body.style.overflow = 'hidden';
    } else {
      document.documentElement.style.setProperty('--ka-sb', '0px');
      document.body.style.overflow = '';
    }
  }

  function openMenu() {
    if (!menu || isAnimating) return;
    isAnimating = true;
    requestAnimationFrame(() => menu?.classList.add('is-open'));
    menu?.setAttribute('aria-hidden', 'false');
    setScrollLock(true);
    toggle?.setAttribute('aria-expanded', 'true');
    toggleButton?.classList.add('is-open');
    window.setTimeout(() => {
      isAnimating = false;
    }, ANIM_MS);
  }

  function closeMenu() {
    if (!menu || isAnimating) return;
    isAnimating = true;
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    setScrollLock(false);
    toggle?.setAttribute('aria-expanded', 'false');
    toggleButton?.classList.remove('is-open');
    window.setTimeout(() => {
      isAnimating = false;
    }, ANIM_MS);
  }

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  /** Hover/focus styling: aktivt punkt + dim de andre (MG-feel). */
  const menuList = menu?.querySelector('.ka-menu-list');
  const menuItems = menu?.querySelectorAll('.ka-menu-item');

  function clearActive() {
    menuList?.classList.remove('is-dimmed');
    menuItems?.forEach((li) => li.classList.remove('is-active'));
  }

  function setActive(el) {
    const li = el?.closest?.('.ka-menu-item');
    if (!li) return;
    menuList?.classList.add('is-dimmed');
    menuItems?.forEach((x) => x.classList.toggle('is-active', x === li));
  }

  /**
   * Smooth hover: brug event delegation på listen, så vi ikke clear'er imellem items
   * (ellers får man et “blink”, når cursoren flytter fra ét punkt til næste).
   */
  menuList?.addEventListener('pointerover', (e) => {
    const a = e.target?.closest?.('.ka-menu-item a');
    if (!a) return;
    setActive(a);
  });

  menuList?.addEventListener('pointerleave', () => {
    clearActive();
  });

  // Keyboard: fokus skal også sætte active, og tab væk skal clear'e igen
  menuList?.addEventListener('focusin', (e) => {
    const a = e.target?.closest?.('.ka-menu-item a');
    if (!a) return;
    setActive(a);
  });

  menuList?.addEventListener('focusout', (e) => {
    // Når fokus forlader hele listen
    if (menuList && !menuList.contains(e.relatedTarget)) {
      clearActive();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && menu.classList.contains('is-open')) closeMenu();
  });
</script>
