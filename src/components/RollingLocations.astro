---
import { getSiteSettings, urlFor } from '../lib/sanity';
import { siteConfig } from '../config/site';

type LocationItem = {
  label: string;
  image?: any;
};

const settings = await getSiteSettings();

const sanityItems: LocationItem[] =
  (settings?.rollingLocations || []).filter((x: any) => typeof x?.label === 'string' && x.label.trim().length > 0);

const fallbackItems: LocationItem[] = siteConfig.tourLocations.flatMap((x) => [
  { label: x.country },
  ...x.cities.map((c) => ({ label: c })),
]);

const items: LocationItem[] = sanityItems.length ? sanityItems : fallbackItems;

function imgUrl(item: LocationItem) {
  if (!item?.image) return '';
  try {
    return urlFor(item.image).width(1800).quality(80).auto('format').url();
  } catch {
    return '';
  }
}

function imageFromRef(ref: any) {
  if (!ref) return '';
  try {
    return urlFor(ref).width(2400).quality(82).auto('format').url();
  } catch {
    return '';
  }
}

/** Standard baggrund: dit AVIF i repo. Sanity “Locations standard baggrund” kan stadig overskrive. */
const LOCATIONS_BG_AVIF = '/images/locations-bg.avif';

const idleBgUrl =
  imageFromRef(settings?.locationsIdleBackground) || LOCATIONS_BG_AVIF;

const sectionLabel = String(settings?.locationsSectionLabel ?? 'TOUR').trim() || 'TOUR';

// Unikke hover-billeder (som MG: .hovered-event-image med stablede <img>)
const hoverImageUrls: string[] = [];
const seenUrl = new Set<string>();
for (const item of items) {
  const u = imgUrl(item);
  if (u && !seenUrl.has(u)) {
    seenUrl.add(u);
    hoverImageUrls.push(u);
  }
}

// Tre rækker
const r1 = items.filter((_, i) => i % 3 === 0);
const r2 = items.filter((_, i) => i % 3 === 1);
const r3 = items.filter((_, i) => i % 3 === 2);
const rowA = r1.length ? r1 : items;
const rowB = r2.length ? r2 : items;
const rowC = r3.length ? r3 : items;

const { loopCount, durationSec, durationHoverSec, showsCtaHref, showsCtaNewTab } =
  siteConfig.locationsMarquee;
const durationCss = `${durationSec}s`;
/** playbackRate ved hover: langsommere uden at genstarte CSS-animation (WAAPI) */
const marqueeHoverPlaybackRate = durationHoverSec > 0 ? durationSec / durationHoverSec : 1;
const loops = Array.from({ length: loopCount }, (_, i) => i);
---

<section
  id="locations"
  class="ka-events-section ka-loc-section relative isolate w-full overflow-x-clip overflow-y-visible bg-black px-2 pb-[clamp(3rem,10vw,5.5rem)] pt-[clamp(1.75rem,5vw,3rem)] sm:px-4"
  aria-label="Tour locations"
>
  <!-- MG: events-section — foto + event-title-marquee + CTA -->
  <div
    class="ka-loc-visual relative w-full overflow-x-clip overflow-y-visible"
    style={`--marquee-loops: ${loopCount}; --marquee-duration: ${durationCss};`}
    data-marquee-hover-rate={String(marqueeHoverPlaybackRate)}
  >
    <!-- MG: foto-boks centreret — max 808×556; CTA i separat lag (z over marquee) med samme bounds -->
    <div class="ka-loc-frame-bounds ka-loc-frame-bounds--media">
      <div
        class="ka-loc-bg-idle"
        style={`background-image: url(${JSON.stringify(idleBgUrl)})`}
        aria-hidden="true"
      ></div>
      <div class="ka-loc-hovered-event-image ka-loc-hover-stack" aria-hidden="true">
        {hoverImageUrls.map((url) => (
          <img
            src={url}
            alt=""
            width="808"
            height="556"
            class="ka-loc-hover-img"
            data-hover-src={url}
            loading="lazy"
            decoding="async"
          />
        ))}
      </div>
    </div>

    <!-- MG: .page-indicator — søskende til marquee, absolut mod hele visual -->
    <div class="ka-loc-page-indicator ka-loc-rail">
      <span class="ka-loc-rail__text">{sectionLabel}</span>
      <span class="ka-loc-rail__line"></span>
    </div>

    <!-- Full width overlay: centreret vertikalt ift. billedets bounds -->
    <div class="ka-loc-event-title-marquee pointer-events-none absolute inset-x-0 z-[15] flex w-full flex-col justify-center">
      <div class="ka-loc-event-title-rows w-full [&_button]:pointer-events-auto">
        <div class="ka-loc-event-title-row ka-marquee ka-marquee--a" aria-hidden="true">
          <div class="ka-marquee__track">
            {loops.map(() => (
              <div class="ka-loc-event-title-row-chunk">
                {rowA.map((item) => (
                  <button
                    type="button"
                    class="ka-outline ka-loc-event-title"
                    data-loc
                    data-bg={imgUrl(item)}
                  >
                    {item.label}
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div class="ka-loc-event-title-row ka-marquee ka-marquee--b" aria-hidden="true">
          <div class="ka-marquee__track">
            {loops.map(() => (
              <div class="ka-loc-event-title-row-chunk">
                {rowB.map((item) => (
                  <button
                    type="button"
                    class="ka-outline ka-loc-event-title"
                    data-loc
                    data-bg={imgUrl(item)}
                  >
                    {item.label}
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div class="ka-loc-event-title-row ka-marquee ka-marquee--c" aria-hidden="true">
          <div class="ka-marquee__track">
            {loops.map(() => (
              <div class="ka-loc-event-title-row-chunk">
                {rowC.map((item) => (
                  <button
                    type="button"
                    class="ka-outline ka-loc-event-title"
                    data-loc
                    data-bg={imgUrl(item)}
                  >
                    {item.label}
                  </button>
                ))}
              </div>
            ))}
          </div>
        </div>

        <div class="sr-only">
          {items.map((i) => i.label).join(', ')}
        </div>
      </div>
    </div>

    <!-- Samme ramme som foto: knap halvt på foto, halvt på sort (som MG “GET YOUR TICKETS”) -->
    <div class="ka-loc-frame-bounds ka-loc-cta-layer pointer-events-none">
      <a
        href={showsCtaHref}
        target={showsCtaNewTab ? '_blank' : undefined}
        rel={showsCtaNewTab ? 'noopener noreferrer' : undefined}
        class="ka-loc-cta-btn ka-btn pointer-events-auto inline-flex min-w-[min(100%,280px)] shrink-0 items-center justify-center bg-white px-14 py-4 text-black transition-colors hover:bg-neutral-200"
      >
        UPCOMING SHOWS
      </a>
    </div>
  </div>
</section>

<style>
  .ka-loc-section {
    background-color: #000;
  }

  .ka-loc-visual {
    min-height: min(58vh, 720px);
    padding-top: clamp(2.25rem, 5vw, 3.25rem);
    /* Halv knap under foto + ekstra luft så intet klippes */
    padding-bottom: clamp(5rem, 14vw, 8.5rem);
    /* Samme bounds bruges af billede + overlay + venstre rail */
    --ka-loc-frame-top: 2.5rem;
    --ka-loc-frame-h: 556px;
  }

  @media (min-width: 768px) {
    .ka-loc-visual {
      min-height: min(62vh, 800px);
      padding-top: clamp(2.75rem, 5vw, 4rem);
      padding-bottom: clamp(5.5rem, 14vw, 9rem);
      --ka-loc-frame-top: 3.5rem;
    }
  }

  .ka-loc-event-title-rows {
    width: 100%;
    max-width: 100%;
    /* Sikrer at samlet hover-zone virker oven på pointer-events-none-forælder */
    pointer-events: auto;
  }

  .ka-loc-event-title-row-chunk {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    gap: clamp(2.5rem, 6vw, 6.5rem);
  }

  /* MG: max 808×556 — delt geometri for foto + CTA-lag */
  .ka-loc-frame-bounds {
    position: absolute;
    left: 50%;
    top: var(--ka-loc-frame-top);
    width: calc(100% - 2rem);
    max-width: 808px;
    height: var(--ka-loc-frame-h);
    transform: translateX(-50%);
  }

  @media (min-width: 768px) {
    .ka-loc-frame-bounds {
      top: var(--ka-loc-frame-top);
    }
  }

  /* Marquee-teksten er full width, men vertikalt låst til billedets højde. */
  .ka-loc-event-title-marquee {
    top: var(--ka-loc-frame-top);
    height: var(--ka-loc-frame-h);
  }

  @media (min-width: 768px) {
    .ka-loc-event-title-marquee {
      top: var(--ka-loc-frame-top);
    }
  }

  @media (max-width: 900px) {
    .ka-loc-frame-bounds {
      height: auto;
      aspect-ratio: 808 / 556;
      max-height: min(52vh, 556px);
    }
  }

  @media (max-width: 900px) {
    .ka-loc-event-title-marquee {
      height: auto;
      aspect-ratio: 808 / 556;
      max-height: min(52vh, 556px);
    }
  }

  @media (max-width: 900px) {
    .ka-loc-rail {
      height: auto;
      aspect-ratio: 808 / 556;
      max-height: min(52vh, 556px);
    }
  }

  .ka-loc-frame-bounds--media {
    z-index: 5;
    contain: layout;
  }

  .ka-loc-cta-layer {
    z-index: 35;
    overflow: visible;
    background: transparent;
  }

  .ka-loc-cta-btn {
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translate(-50%, 50%);
  }

  .ka-loc-bg-idle {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  .ka-loc-hovered-event-image,
  .ka-loc-hover-stack {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
  }

  .ka-loc-hover-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 320ms ease;
  }

  .ka-loc-hover-img.is-on {
    opacity: 1;
  }

  /* Venstre label + linje: kun absolute — påvirker ikke flow, ligger over indhold */
  .ka-loc-rail {
    pointer-events: none;
    position: absolute;
    left: 0.75rem;
    top: var(--ka-loc-frame-top);
    bottom: auto;
    height: var(--ka-loc-frame-h);
    z-index: 30;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.55rem;
    width: max-content;
    max-width: min(4.5rem, 18vw);
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  @media (min-width: 640px) {
    .ka-loc-rail {
      left: 1.25rem;
      gap: 0.65rem;
    }
  }

  .ka-loc-rail__text {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
    white-space: nowrap;
    line-height: 1;
    padding-top: 2px;
  }

  .ka-loc-rail__line {
    width: 1px;
    flex: 1 1 auto;
    align-self: stretch;
    min-height: 5rem;
    background: rgba(255, 255, 255, 0.38);
  }

  .ka-marquee {
    overflow: hidden;
    padding: 14px 0 18px;
    background: transparent;
    /* Så hele rækken (ikke kun knapper) kan hover’es; forælder har pointer-events-none */
    pointer-events: auto;
    --duration: var(--marquee-duration, 36s);
    /* Mindre layout-arbejde for browseren under animation */
    contain: layout;
  }

  .ka-marquee--b,
  .ka-marquee--c {
    margin-top: 0;
    opacity: 0.95;
  }

  .ka-marquee__track {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: clamp(2.5rem, 6vw, 6.5rem);
    width: max-content;
    animation: ka-marquee-left var(--duration, 10s) linear infinite;
    /* GPU-compositor: translate3d i keyframes + ingen permanent will-change (mindre RAM/jank på mobil) */
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  /* Modsat retning — samme keyframes som MG row 2 */
  .ka-marquee--b .ka-marquee__track {
    animation: ka-marquee-left var(--duration, 10s) linear infinite reverse;
  }

  .ka-marquee--c .ka-marquee__track {
    animation: ka-marquee-left var(--duration, 10s) linear infinite;
  }

  @keyframes ka-marquee-left {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(calc(-100% / var(--marquee-loops, 6)), 0, 0);
    }
  }

  .ka-outline {
    -webkit-appearance: none;
    appearance: none;
    margin: 0;
    background: transparent;
    border: none !important;
    box-shadow: none !important;
    padding: 0;
    cursor: default;
    font-family: inherit;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    font-size: clamp(30px, 7.2vw, 104px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.92);
    text-stroke: 1px rgba(255, 255, 255, 0.92);
    transition: color 160ms ease;
    white-space: nowrap;
    user-select: none;
    position: relative;
    z-index: 15;
    /* Mindre rasterizing af store outline-tekster under bevægelse */
    text-rendering: geometricPrecision;
  }

  .ka-outline:hover,
  .ka-outline:focus-visible {
    color: #fff;
  }

  .ka-outline:focus {
    outline: none;
  }

  .ka-outline:focus-visible {
    outline: 2px solid rgba(220, 255, 66, 0.9);
    outline-offset: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .ka-marquee__track {
      animation: none !important;
    }
  }
</style>

<script>
  /** Modul-scripts har document.currentScript === null; brug id fra sektionen. */
  const root = document.getElementById('locations');
  if (root) {
    const visual = root.querySelector('.ka-loc-visual');
    const rawRate = parseFloat(visual?.getAttribute('data-marquee-hover-rate') || '');
    const hoverRate = Number.isFinite(rawRate)
      ? Math.min(1, Math.max(0.05, rawRate))
      : 0.3;

    /** Marquee: langsom ved hover via playbackRate — én zone for alle rækker (undgår hak række → række). */
    const setAllPlayback = (rate) => {
      root.querySelectorAll('.ka-marquee__track').forEach((track) => {
        for (const anim of track.getAnimations()) {
          anim.playbackRate = rate;
        }
      });
    };

    const titleRows = root.querySelector('.ka-loc-event-title-rows');
    titleRows?.addEventListener('pointerenter', () => setAllPlayback(hoverRate));
    titleRows?.addEventListener('pointerleave', () => setAllPlayback(1));

    const hoverImgs = root.querySelectorAll('.ka-loc-hover-img');

    const setHover = (url) => {
      hoverImgs.forEach((img) => {
        const src = img.getAttribute('data-hover-src') || '';
        img.classList.toggle('is-on', Boolean(url) && src === url);
      });
    };

    root.querySelectorAll('[data-loc]').forEach((el) => {
      el.addEventListener('mouseenter', () => {
        setHover(el.getAttribute('data-bg') || '');
      });
      el.addEventListener('focus', () => {
        setHover(el.getAttribute('data-bg') || '');
      });
    });
  }
</script>
