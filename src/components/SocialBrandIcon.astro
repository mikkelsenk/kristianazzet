---
import type { SocialBrandId } from '../data/socialBrandPaths';
import { SOCIAL_BRAND_PATHS } from '../data/socialBrandPaths';

interface Props {
  brand: SocialBrandId;
  size?: number;
  class?: string;
}

const { brand, size = 20, class: className } = Astro.props;
const { d } = SOCIAL_BRAND_PATHS[brand];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="currentColor"
  class={className}
  aria-hidden="true"
>
  <path d={d} />
</svg>
