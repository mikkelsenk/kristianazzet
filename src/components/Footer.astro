---
import { siteConfig } from '../config/site';
import type { SocialBrandId } from '../data/socialBrandPaths';
import SocialBrandIcon from './SocialBrandIcon.astro';

const year = new Date().getFullYear();
const { social, music, unchartedCulture } = siteConfig;

/** Samme rækkefølge som `src/pages/sitemap.xml.ts` */
const sitemapLinks: { label: string; href: string }[] = [
  { label: 'Home', href: '/' },
  { label: 'Shows', href: '/shows' },
  { label: 'Music', href: '/music' },
  { label: 'Contact', href: '/contact' },
  { label: 'Firmafest', href: '/firmafest' },
  { label: 'Terms', href: '/terms' },
  { label: 'Privacy', href: '/privacy' },
  { label: 'Cookies', href: '/cookies' },
];

const r1 = sitemapLinks.filter((_, i) => i % 3 === 0);
const r2 = sitemapLinks.filter((_, i) => i % 3 === 1);
const r3 = sitemapLinks.filter((_, i) => i % 3 === 2);
const rowA = r1.length ? r1 : sitemapLinks;
const rowB = r2.length ? r2 : sitemapLinks;
const rowC = r3.length ? r3 : sitemapLinks;

/** Række af ikoner — én celle pr. platform (som MG 8 felter); brand = officielle Simple Icons-glyfer */
const socialCells: { label: string; href: string; brand: SocialBrandId }[] = [
  { label: 'Instagram', href: social.instagram, brand: 'instagram' },
  { label: 'YouTube', href: social.youtube, brand: 'youtube' },
  { label: 'Spotify', href: music.spotify, brand: 'spotify' },
  { label: 'Facebook', href: social.facebook, brand: 'facebook' },
  { label: 'TikTok', href: social.tiktok, brand: 'tiktok' },
  { label: 'X', href: social.twitter, brand: 'x' },
  { label: 'LinkedIn', href: social.linkedin, brand: 'linkedin' },
  { label: 'SoundCloud', href: music.soundcloud, brand: 'soundcloud' },
];
---

<footer id="footer" class="ka-footer w-full border-t border-white/10 bg-black">
  <div class="ka-footer__inner mx-auto w-full max-w-[min(100%,90rem)] px-4 pb-16 pt-16 sm:px-6 lg:px-10 xl:px-14">
    <!-- 1. Follow me + ikonrække (MG: ramme + lodrette streger) -->
    <section class="ka-footer__follow text-center" aria-labelledby="footer-follow-heading">
      <p
        id="footer-follow-heading"
        class="font-sans text-lg font-normal tracking-wide text-white md:text-xl"
      >
        Follow me
      </p>
      <div class="ka-footer-social mx-auto mt-6 grid max-w-5xl" role="list">
        {
          socialCells.map(({ label, href, brand }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              role="listitem"
              class="ka-footer-social__cell flex aspect-square items-center justify-center text-white/85 transition-colors duration-200 hover:bg-white hover:text-black"
              aria-label={label}
            >
              <SocialBrandIcon brand={brand} size={20} />
            </a>
          ))
        }
      </div>
    </section>

    <!-- 2. Sitemap — stor outline-type (statisk, ingen rulle) -->
    <nav class="ka-footer__sitemap-nav mt-14 md:mt-20" aria-label="Sitemap">
      <div class="ka-ftr-sitemap-visual w-full py-2">
        <div class="ka-ftr-sitemap-rows">
          <div class="ka-ftr-sitemap-row">
            {
              rowA.map(({ label, href }) => (
                <a href={href} class="ka-ftr-outline">
                  {label}
                </a>
              ))
            }
          </div>
          <div class="ka-ftr-sitemap-row ka-ftr-sitemap-row--muted">
            {
              rowB.map(({ label, href }) => (
                <a href={href} class="ka-ftr-outline">
                  {label}
                </a>
              ))
            }
          </div>
          <div class="ka-ftr-sitemap-row">
            {
              rowC.map(({ label, href }) => (
                <a href={href} class="ka-ftr-outline">
                  {label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </nav>

    <!-- 3. Uncharted Culture — samme sprog som Contact + newsletter (mørk flade, ka-label, neon CTA) -->
    <div class="ka-footer__uc mt-14 md:mt-20">
      <a
        href={unchartedCulture.url}
        target="_blank"
        rel="noopener noreferrer"
        class="ka-footer__uc-card group relative block overflow-hidden border border-white/10 bg-[#070707] transition-default before:pointer-events-none before:absolute before:inset-y-0 before:left-0 before:w-[3px] before:bg-gradient-to-b before:from-neon-green/70 before:via-neon-green/25 before:to-transparent before:opacity-90 before:transition-opacity hover:border-white/[0.14] hover:before:opacity-100"
      >
        <div
          class="relative grid gap-0 md:grid-cols-[minmax(0,1fr)_minmax(12rem,17rem)] md:items-stretch"
        >
          <div class="min-w-0 border-b border-white/10 px-6 py-9 sm:px-8 sm:py-10 md:border-b-0 md:border-r md:py-11 md:pl-9 md:pr-10 lg:pl-10">
            <p class="ka-label ka-label--accent mb-3">{unchartedCulture.eyebrow}</p>
            <h2
              class="font-display text-[clamp(1.5rem,4vw,2.25rem)] font-bold uppercase tracking-tight text-white"
            >
              {unchartedCulture.title}
            </h2>
            <p class="mt-4 max-w-xl text-sm leading-relaxed text-white/65 md:text-base">
              {unchartedCulture.description}
            </p>
            <ul class="mt-6 flex flex-wrap gap-2" role="list">
              {
                unchartedCulture.highlights.map((line) => (
                  <li>
                    <span class="inline-flex border border-white/[0.08] bg-black/30 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-[0.14em] text-white/50 transition-colors group-hover:border-white/15 group-hover:text-white/65">
                      {line}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="flex flex-col justify-center gap-4 px-6 py-8 sm:px-8 md:px-9 md:py-11 lg:px-10">
            <span
              class="ka-btn inline-flex w-full items-center justify-center gap-2.5 bg-neon-green px-6 py-4 text-stone-black shadow-[0_6px_28px_rgba(220,255,66,0.18)] transition-default group-hover:bg-white group-hover:shadow-[0_8px_32px_rgba(255,255,255,0.12)]"
            >
              Visit site
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                aria-hidden="true"
              >
                <path d="M7 17L17 7M17 7H9M17 7v8"></path>
              </svg>
            </span>
            <p class="text-center text-[0.65rem] uppercase tracking-[0.2em] text-white/35 md:text-left">
              unchartedculture.com
            </p>
          </div>
        </div>
      </a>
    </div>

    <!-- 4. Meta: © | vilkår -->
    <div
      class="ka-footer__meta mt-12 flex flex-col gap-8 border-t border-white/10 pt-10 md:mt-14 md:flex-row md:items-center md:justify-between"
    >
      <p class="text-xs uppercase tracking-[0.12em] text-white/45">
        © {year}
        <a href="/" class="transition-colors hover:text-white">{siteConfig.name}</a>
      </p>
      <ul class="flex flex-wrap gap-x-8 gap-y-2 text-xs uppercase tracking-[0.12em] text-white/45">
        <li>
          <a href="/terms" class="transition-colors hover:text-white">Terms & Conditions</a>
        </li>
        <li>
          <a href="/privacy" class="transition-colors hover:text-white">Privacy Policy</a>
        </li>
        <li>
          <a href="/cookies" class="transition-colors hover:text-white">Cookies Policy</a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .ka-footer-social {
    width: 100%;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
  .ka-footer-social__cell {
    border-right: 1px solid rgba(255, 255, 255, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .ka-footer-social__cell:nth-child(4n) {
    border-right-width: 0;
  }
  .ka-footer-social__cell:nth-last-child(-n + 4) {
    border-bottom-width: 0;
  }
  @media (min-width: 640px) {
    .ka-footer-social {
      grid-template-columns: repeat(8, minmax(0, 1fr));
    }
    .ka-footer-social__cell {
      border-bottom-width: 0;
    }
    .ka-footer-social__cell:nth-child(4n) {
      border-right-width: 1px;
    }
    .ka-footer-social__cell:nth-child(8n) {
      border-right-width: 0;
    }
  }

  /* Sitemap — outline som locations-sektionen, men uden marquee */
  .ka-ftr-sitemap-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
    align-items: stretch;
  }

  .ka-ftr-sitemap-row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: clamp(1.25rem, 4vw, 3.5rem);
    padding: 10px 0 12px;
  }

  .ka-ftr-sitemap-row--muted {
    opacity: 0.95;
  }

  .ka-ftr-outline {
    margin: 0;
    text-decoration: none;
    font-family: 'Geomanist', system-ui, sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 0.95;
    font-size: clamp(28px, 6.5vw, 88px);
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.92);
    text-stroke: 1px rgba(255, 255, 255, 0.92);
    transition:
      color 160ms ease,
      -webkit-text-stroke-color 160ms ease;
    white-space: nowrap;
    position: relative;
    z-index: 2;
    text-rendering: geometricPrecision;
  }

  .ka-ftr-outline:hover,
  .ka-ftr-outline:focus-visible {
    color: #fff;
    -webkit-text-stroke-color: transparent;
  }

  .ka-ftr-outline:focus-visible {
    outline: 2px solid rgba(220, 255, 66, 0.9);
    outline-offset: 6px;
  }
</style>
