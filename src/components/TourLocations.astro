---
import { siteConfig } from '../config/site';

const { tourLocations } = siteConfig;
---

<section
  id="locations"
  class="relative scroll-mt-24 border-t border-white/10 bg-black px-6 py-24 md:px-10 md:py-32"
  aria-labelledby="locations-heading"
>
  <div class="mx-auto flex max-w-container flex-col gap-16 lg:flex-row lg:gap-20">
    <div class="hidden shrink-0 flex-col items-start gap-8 lg:flex lg:w-40">
      <div class="h-40 w-px bg-white/20" aria-hidden="true"></div>
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white/45 [writing-mode:vertical-rl]">
        On the road
      </p>
    </div>

    <div class="min-w-0 flex-1">
      <p class="ka-label ka-label--accent mb-4">Personligt</p>
      <h2
        id="locations-heading"
        class="font-display text-4xl uppercase tracking-tight text-white md:text-6xl md:leading-[1.02]"
      >
        Lande &amp; byer
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-white/80 md:text-lg">
        Et udpluk af steder jeg har spillet — fra klub til festival. Listen opdateres løbende; det er en del af min historie som DJ.
      </p>

      <div class="mt-16 grid grid-cols-1 gap-14 sm:grid-cols-2 xl:grid-cols-3">
        {tourLocations.map(({ country, cities }) => (
          <div class="border-t border-white/10 pt-8">
            <h3 class="text-lg font-bold uppercase tracking-wide text-white md:text-xl">{country}</h3>
            <ul class="mt-5 space-y-2.5 text-base text-white/75">
              {cities.map((city) => (
                <li class="flex gap-3">
                  <span class="text-neon-green" aria-hidden="true">
                    ·
                  </span>
                  <span>{city}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
